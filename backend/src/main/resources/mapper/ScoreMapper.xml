<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.qi.backend.mapper.ScoreMapper">

    <!-- 基础结果映射 -->
    <resultMap id="ScoreResultMap" type="com.qi.backend.entity.Score">
        <id column="id" property="id"/>
        <result column="student_no" property="studentNo"/>
        <result column="course_name" property="courseName"/>
        <result column="score" property="score"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 新增成绩 -->
    <insert id="insertScore">
        insert into scores
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="studentNo != null">student_no,</if>
            <if test="courseName != null">course_name,</if>
            <if test="score != null">score,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="studentNo != null">#{studentNo},</if>
            <if test="courseName != null">#{courseName},</if>
            <if test="score != null">#{score},</if>
        </trim>
    </insert>

    <!-- 修改成绩 -->
    <update id="updateScoreById">
        update scores
        <set>
            <if test="studentNo != null">student_no = #{studentNo},</if>
            <if test="courseName != null">course_name = #{courseName},</if>
            <if test="score != null">score = #{score},</if>
        </set>
        where id = #{id}
    </update>

    <!-- 根据ID查询 -->
    <select id="selectScoreById" resultMap="ScoreResultMap">
        select * from scores where id = #{id}
    </select>

    <!-- 根据学号查询所有成绩，学生调用-->
    <select id="selectScoresByStudentNo" resultMap="ScoreResultMap">
        select * from scores
        where student_no = #{studentNo}
        order by create_time desc
    </select>

    <!-- 前端毕业资格展示 -->
    <resultMap id="StudentScoreGraduateResultMap" type="com.qi.backend.model.StudentScoreGraduateModel">
        <result column="student_id" property="studentId"/>
        <result column="student_no" property="studentNo"/>
        <result column="real_name" property="realName"/>
        <result column="college_name" property="collegeName"/>
        <result column="major_name" property="majorName"/>
        <result column="fail_count" property="failCount"/>
        <result column="graduate_status" property="graduateStatus"/>
    </resultMap>

    <select id="selectStudentScoreGraduateList" resultMap="StudentScoreGraduateResultMap">
        select
            s.student_id,
            s.student_no,
            s.real_name,
            c.college_name,
            m.major_name,
            IFNULL(SUM(CASE WHEN sc.score &lt; 60 THEN 1 ELSE 0 END), 0) as fail_count,
            IFNULL(SUM(CASE WHEN sc.score &lt; 60 THEN 1 ELSE 0 END), 0) = 0 as graduate_status
        from student_info s
        left join colleges c on s.college_id = c.college_id
        left join majors m on s.major_id = m.major_id
        left join scores sc on s.student_no = sc.student_no
        where s.student_status = '在读'
        <if test="collegeId != null">
            and s.college_id = #{collegeId}
        </if>
        <if test="majorId != null">
            and s.major_id = #{majorId}
        </if>
        group by s.student_id, s.student_no, s.real_name, c.college_name, m.major_name
        order by s.student_no asc
    </select>

    <!-- 根据学号+课程名查询成绩 导入判重 -->
    <select id="selectByStudentNoAndCourseName" resultMap="ScoreResultMap">
        select * from scores
        where student_no = #{studentNo}
        and course_name = #{courseName}
    </select>
</mapper>