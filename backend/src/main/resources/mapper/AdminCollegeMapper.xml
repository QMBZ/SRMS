<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.qi.backend.mapper.AdminCollegeMapper">

    <!-- 结果映射 -->
    <resultMap id="AdminCollegeResultMap" type="com.qi.backend.entity.AdminCollege">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="college_id" property="collegeId"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 根据学院ID查询管理员 -->
    <select id="selectByCollegeId" resultMap="AdminCollegeResultMap">
        select * from admin_college where college_id = #{collegeId}
    </select>

    <!-- 根据用户ID查询唯一绑定关系 -->
    <select id="selectByUserId" resultMap="AdminCollegeResultMap">
        select * from admin_college where user_id = #{userId}
    </select>

    <!-- 查询全部 -->
    <select id="selectAll" resultMap="AdminCollegeResultMap">
        select * from admin_college order by create_time desc
    </select>

    <!-- 新增 -->
    <insert id="insertAdminCollege">
        insert into admin_college(user_id, college_id)
        values(#{userId}, #{collegeId})
    </insert>

    <!-- 根据ID删除 -->
    <delete id="deleteById">
        delete from admin_college where id = #{id}
    </delete>

    <!-- 根据用户ID+学院ID删除（解绑） -->
    <delete id="deleteByUserIdAndCollegeId">
        delete from admin_college where user_id = #{userId} and college_id = #{collegeId}
    </delete>

</mapper>