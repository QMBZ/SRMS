<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.qi.backend.mapper.UserMapper">
    <!-- 返回 Map -->
    <resultMap id="UserResultMap" type="com.qi.backend.entity.User">
        <id column="user_id" property="userId"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="real_name" property="realName"/>
        <result column="role_id" property="roleId"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 获取所有用户 -->
    <select id="selectAllUsers" resultMap="UserResultMap">
        select * from users
    </select>

    <!-- 根据 ID 获取用户 -->
    <select id="selectUserById" resultMap="UserResultMap">
        select * from users where user_id = #{userId}
    </select>

    <!-- 根据用户名（学号/工号）获取用户 -->
    <select id="selectUserByUsername" resultMap="UserResultMap">
        select * from users where username = #{username}
    </select>

    <!-- 通过角色筛选用户 -->
    <select id="selectUsersByRoleId" resultMap="UserResultMap">
        select * from users where role_id = #{roleId}
    </select>

    <!-- 通过账号状态筛选 -->
    <select id="selectUsersByStatus" resultMap="UserResultMap">
        select * from users where status = #{status}
    </select>

    <!-- 分页查询所有用户（配合 PageHelper 使用） -->
    <select id="selectUsersByPage" resultMap="UserResultMap">
        select * from users order by create_time desc
    </select>

    <!-- 多条件分页查询 -->
    <select id="selectUsersByConditionPage" resultMap="UserResultMap">
        select * from users
        <where>
            <if test="user.realName != null and user.realName != ''">
                and real_name like concat('%', #{user.realName}, '%')
            </if>
            <if test="user.username != null and user.username != ''">
                and username like concat('%', #{user.username}, '%')
            </if>
            <if test="user.roleId != null">
                and role_id = #{user.roleId}
            </if>
            <if test="user.status != null">
                and status = #{user.status}
            </if>
        </where>
        order by create_time desc
    </select>

    <!-- 新增用户 -->
    <insert id="insertUser">
        insert into users(username, password, real_name, role_id, status)
        values(#{username}, #{password}, #{realName}, #{roleId}, #{status})
    </insert>

    <!-- 修改用户 -->
    <update id="updateUser">
        update users
        <set>
            <if test="password != null">password = #{password},</if>
            <if test="realName != null">real_name = #{realName},</if>
            <if test="roleId != null">role_id = #{roleId},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        where user_id = #{userId}
    </update>

    <!-- 修改用户 -->
    <update id="updateUserStatus">
        update users set status = #{status} where user_id = #{userId}
    </update>
</mapper>